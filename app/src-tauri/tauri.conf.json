{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AstraShell",
  "version": "0.3.16",
  "identifier": "ai.astrashell.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "AstraShell",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "GetIDC",
    "copyright": "Copyright © 2026 GetIDC",
    "category": "DeveloperTool",
    "shortDescription": "SSH/SFTP/Serial Terminal Manager",
    "longDescription": "AstraShell is a modern SSH, SFTP, and Serial terminal manager with code snippets and key vault features."
  }
}
